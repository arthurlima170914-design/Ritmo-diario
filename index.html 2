<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Ritmo Diário</title>

<style>
body {
  margin:0;
  font-family:Arial;
  background:#f3e8ff;
  color:#4c1d95;
}

header {
  text-align:center;
  padding:20px;
}

.container {
  padding:20px;
}

input {
  width:65%;
  padding:10px;
  border-radius:10px;
  border:none;
}

button {
  padding:10px;
  border:none;
  border-radius:10px;
  background:#7c3aed;
  color:white;
}

.habit {
  display:flex;
  justify-content:space-between;
  background:white;
  padding:10px;
  margin-top:10px;
  border-radius:10px;
}

.circle {
  width:22px;
  height:22px;
  border-radius:50%;
  border:2px solid #7c3aed;
}

.checked {
  background:#7c3aed;
}

.stats {
  background:white;
  padding:10px;
  border-radius:10px;
  margin-bottom:15px;
}
</style>
</head>

<body>

<header>
  <h1>Ritmo Diário</h1>
  <p>1% melhor a cada dia</p>
  <p id="date"></p>
</header>

<div class="container">

<div class="stats">
  <p>Progresso hoje: <span id="progress">0%</span></p>
  <p>Sequência 🔥: <span id="streak">0</span> dias</p>
</div>

<input id="input" placeholder="Novo hábito">
<button onclick="addHabit()">+</button>

<div id="list"></div>

</div>

<script>

let habits = JSON.parse(localStorage.getItem("habits")) || [];

let today = new Date().toISOString().slice(0,10);
document.getElementById("date").innerText = today;

function save(){
  localStorage.setItem("habits", JSON.stringify(habits));
}

function addHabit(){
  const input = document.getElementById("input");
  if(!input.value) return;

  habits.push({
    name: input.value,
    history: {}
  });

  input.value="";
  save();
  render();
}

function toggle(i){
  let h = habits[i];

  if(!h.history) h.history = {};

  h.history[today] = !h.history[today];

  save();
  render();
}

function removeHabit(i){
  habits.splice(i,1);
  save();
  render();
}

function calcProgress(){
  let total = habits.length;
  let done = habits.filter(h => h.history && h.history[today]).length;

  let percent = total ? Math.round((done/total)*100) : 0;

  document.getElementById("progress").innerText = percent + "%";
}

function calcStreak(){
  let streak = 0;

  for(let d=0; d<30; d++){
    let date = new Date();
    date.setDate(date.getDate()-d);
    let key = date.toISOString().slice(0,10);

    let allDone = habits.length > 0 && habits.every(h => h.history && h.history[key]);

    if(allDone) streak++;
    else break;
  }

  document.getElementById("streak").innerText = streak;
}

function render(){
  const list = document.getElementById("list");
  list.innerHTML="";

  habits.forEach((h,i)=>{
    list.innerHTML += `
      <div class="habit">
        <span>${h.name}</span>
        <div>
          <span onclick="toggle(${i})" class="circle ${h.history && h.history[today] ? "checked":""}"></span>
          <button onclick="removeHabit(${i})">❌</button>
        </div>
      </div>
    `;
  });

  calcProgress();
  calcStreak();
}

render();

</script>

</body>
</html>
